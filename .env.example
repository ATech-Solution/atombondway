# ============================================================
# MAINTENANCE MODE
# Set to "true" to show the under-construction page to all visitors.
# Admin panel (/admin) and API (/api) remain accessible.
# ============================================================
MAINTENANCE_MODE=false

# ============================================================
# APPLICATION
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ============================================================
# PAYLOAD CMS
# Generate a strong secret: openssl rand -base64 32
# ============================================================
PAYLOAD_SECRET=change-this-to-a-strong-random-secret

# ============================================================
# DATABASE (SQLite)
# Format: file:./data/payload.db  (relative from project root)
# On production VPS use an absolute path:
#   file:/var/www/compro/data/payload.db
# ============================================================
DATABASE_URL=file:./data/payload.db

# ============================================================
# EMAIL - AWS SES (Production)
# Leave AWS_SES_SMTP_USER blank to fall back to Mailpit (dev)
# ============================================================
AWS_SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
AWS_SES_SMTP_PORT=465
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Company Name

# ============================================================
# EMAIL - Mailpit (Local Development / Fallback)
# Run Mailpit: docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# View emails at: http://localhost:8025
# ============================================================
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

# ============================================================
# SITE DOMAIN (used for SEO canonical URLs)
# ============================================================
NEXT_PUBLIC_DOMAIN=https://yourdomain.com
